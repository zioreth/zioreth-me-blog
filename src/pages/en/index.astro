---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog', ({ data }) => data.lang === 'en' && !data.draft))
  .sort((a,b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 6);
const fmtDate = (d: Date) => {
  const month = d.toLocaleDateString('es-CO', { month: 'short' }).replace('.', '').toLowerCase();
  const day = d.toLocaleDateString('es-CO', { day: '2-digit' });
  const year = d.toLocaleDateString('es-CO', { year: 'numeric' });
  return { month, day, year };
};
---
<!doctype html>
<html lang="en">
  <head><BaseHead title={`${SITE_TITLE} — Blog`} description="Ideas and opinion about tech and building on the internet." lang="en" /></head>
  <body>
    <Header />
    <main>
      <section class="hero" id="hero">
        <h1>Ideas and opinions to <span class="accent">build</span> on the internet.</h1>
        <p>A personal blog about technology, product, design, and process. Useful takes only.</p>
      </section>
      <h2 class="section-title">Latest posts</h2>
      <section class="posts-grid">
        {posts.map((post) => (
          <a class="post-card" href={`/en/blog/${post.id}/`}>
            <div class="media-wrap">
              {post.data.heroImage && <Image src={post.data.heroImage} alt={post.data.title} width={800} />}
            </div>
            <h3>{post.data.title}</h3>
            <p class="card-taxonomy"><span class="chip chip-date">{fmtDate(post.data.pubDate).month} {fmtDate(post.data.pubDate).day} <span class="slash">/</span> {fmtDate(post.data.pubDate).year}</span><span class="taxonomy-dot">•</span><span class="chip">{post.data.category}</span></p>
            <p>{post.data.description}</p>
          </a>
        ))}
      </section>
    </main>
    <Footer />
  </body>
</html>
