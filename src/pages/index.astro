---
import BaseHead from '../components/BaseHead.astro';

const links = [
  { label: 'Blog', href: 'https://blog.zioreth.me' },
  { label: 'YouTube', href: 'https://youtube.com/@zioreth' },
  { label: 'X / Twitter', href: 'https://x.com/zioreth' },
  { label: 'Instagram', href: 'https://instagram.com/zioreth' },
  { label: 'GitHub', href: 'https://github.com/zioreth' },
];
---
<!doctype html>
<html lang="es">
  <head>
    <BaseHead
      title="Zio — Links"
      description="Todos mis enlaces en un solo lugar."
      lang="es"
    />
  </head>
  <body>
    <main class="links-main">
      <section class="links-card">
        <img
          class="avatar"
          src="https://avatars.githubusercontent.com/u/411611523?v=4"
          alt="Foto de Zio"
          loading="lazy"
          decoding="async"
        />
        <h1>Zio</h1>
        <p class="bio">Creador digital · sistemas, ideas y proyectos en internet.</p>

        <nav class="links-list" aria-label="Enlaces principales">
          {links.map((link) => (
            <a class="link-btn" href={link.href} target="_blank" rel="noopener noreferrer">
              {link.label}
            </a>
          ))}
        </nav>
      </section>
    </main>
  </body>
</html>

<style>
  :root {
    --bg-a: #060b18;
    --bg-b: #111827;
    --card: #0f172acc;
    --text: #e5e7eb;
    --muted: #9ca3af;
    --line: #263244;
    --accent: #22d3ee;
  }

  .links-main {
    min-height: 100vh;
    display: grid;
    place-items: center;
    padding: 24px;
    background: linear-gradient(180deg, var(--bg-a), var(--bg-b));
  }

  .links-card {
    width: min(92vw, 460px);
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: 20px;
    padding: 28px;
    text-align: center;
    backdrop-filter: blur(10px);
  }

  .avatar {
    width: 96px;
    height: 96px;
    border-radius: 999px;
    object-fit: cover;
    border: 2px solid var(--accent);
  }

  h1 {
    margin: 14px 0 6px;
    color: var(--text);
    font-size: 1.65rem;
  }

  .bio {
    margin: 0 0 18px;
    color: var(--muted);
    line-height: 1.45;
  }

  .links-list {
    display: grid;
    gap: 10px;
  }

  .link-btn {
    display: block;
    text-decoration: none;
    color: var(--text);
    background: #152033;
    border: 1px solid #2b3b52;
    border-radius: 12px;
    padding: 12px 14px;
    font-weight: 600;
    transition: all 0.18s ease;
  }

  .link-btn:hover {
    border-color: var(--accent);
    transform: translateY(-1px);
  }
</style>
