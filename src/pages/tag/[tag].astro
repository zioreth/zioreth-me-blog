---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { Image } from 'astro:assets';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => data.lang === 'es' && !data.draft);
  const tags = [...new Set(posts.flatMap((p) => p.data.tags || []))];
  return tags.map((tag) => ({ params: { tag }, props: { tag } }));
}

const { tag } = Astro.props;
const posts = (await getCollection('blog', ({ data }) => data.lang === 'es' && !data.draft && (data.tags || []).includes(tag)))
  .sort((a,b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const fmtDate = (d: Date) => {
  const month = d.toLocaleDateString('es-CO', { month: 'short' }).replace('.', '').toLowerCase();
  const day = d.toLocaleDateString('es-CO', { day: '2-digit' });
  const year = d.toLocaleDateString('es-CO', { year: 'numeric' });
  return { month, day, year };
};
---
<!doctype html>
<html lang="es">
  <head><BaseHead title={`Tag: #${tag}`} description={`Posts con #${tag}`} lang="es" /></head>
  <body>
    <Header />
    <main>
      <section class="hero">
        <h1>Tag: <span class="accent">#{tag}</span></h1>
        <p><a href="/blog">← Volver a El Archivo</a></p>
      </section>
      <section class="posts-grid">
        {posts.map((post) => (
          <a class="post-card" href={`/blog/${post.id}/`}>
            <div class="media-wrap">{post.data.heroImage && <Image src={post.data.heroImage} alt={post.data.title} width={800} />}</div>
            <h3>{post.data.title}</h3>
            <p class="card-taxonomy"><span class="chip chip-date">{fmtDate(post.data.pubDate).month} {fmtDate(post.data.pubDate).day} <span class="slash">/</span> {fmtDate(post.data.pubDate).year}</span><span class="taxonomy-dot">•</span><span class="chip">{post.data.category}</span></p>
            <p>{post.data.description}</p>
          </a>
        ))}
      </section>
    </main>
    <Footer />
  </body>
</html>
